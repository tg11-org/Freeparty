DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
SECRET_KEY=replace-with-strong-secret
BIND_IP=127.0.0.1
WEB_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
SMTP_PORT=1025
MAILHOG_UI_PORT=8025
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SITE_SCHEME=http
SITE_DOMAIN=localhost:8000
DATABASE_URL=postgres://freeparty:freeparty@db:5432/freeparty
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@freeparty.local
EMAIL_VERIFICATION_REQUIRED=True
FEATURE_PM_E2E_ENABLED=False
FEATURE_PM_DEV_CIPHERTEXT_PREVIEW=False
API_THROTTLE_USER=120/min
API_THROTTLE_ANON=60/min
