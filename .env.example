DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
SECRET_KEY=replace-with-strong-secret
BIND_IP=127.0.0.1
WEB_PORT=8000
DB_PORT=5432
POSTGRES_DB=freeparty
POSTGRES_USER=freeparty
POSTGRES_PASSWORD=replace-with-random-local-password
REDIS_PORT=6379
SMTP_PORT=1025
MAILHOG_UI_PORT=8025
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SITE_SCHEME=http
SITE_DOMAIN=localhost:8000
DATABASE_URL=postgres://freeparty:replace-with-random-local-password@db:5432/freeparty
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_BEAT_SCHEDULE_FILENAME=/tmp/celerybeat-schedule
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@freeparty.local
EMAIL_VERIFICATION_REQUIRED=True
LEGAL_TOS_VERSION=1.1
LEGAL_GUIDELINES_VERSION=1.1
ACCOUNT_DELETION_RETENTION_DAYS=30
ACCOUNT_DEACTIVATION_RETENTION_DAYS=365
ACCOUNT_PURGE_ENABLED=True
ACCOUNT_PURGE_CRON_HOUR=3
ACCOUNT_PURGE_CRON_MINUTE=15
FEATURE_PM_E2E_ENABLED=False
FEATURE_PM_DEV_CIPHERTEXT_PREVIEW=False
FEATURE_LINK_UNFURL_ENABLED=False
FEATURE_PM_WEBSOCKET_ENABLED=False
FEATURE_INDEXED_HASHTAG_SEARCH_ENABLED=True
FEATURE_ADAPTIVE_ABUSE_CONTROLS_ENABLED=True
ABUSE_VELOCITY_BLOCK_ENABLED=True
ABUSE_MINIMUM_ACCOUNT_AGE_DAYS_FOR_TRUST=7
ABUSE_EMAIL_VERIFICATION_TRUST_BONUS=25
ABUSE_RECENT_REPORT_PENALTY_PER_REPORT=10
ABUSE_RECENT_ACTION_PENALTY_PER_ACTION=15
ABUSE_TRUST_SCORE_THROTTLE_THRESHOLD=30
ABUSE_THRESHOLD_POSTS_PER_HOUR=5
ABUSE_THRESHOLD_FOLLOWS_PER_HOUR=10
ABUSE_THRESHOLD_LIKES_PER_HOUR=20
ABUSE_THRESHOLD_REPOSTS_PER_HOUR=10
ABUSE_THROTTLE_RECENT_ACTIONS_COUNT_THRESHOLD=3
ABUSE_THROTTLE_RECENT_REPORTS_COUNT_THRESHOLD=4
ABUSE_THROTTLE_RECENT_ACTIONS_DAYS=7
ABUSE_THROTTLE_RECENT_REPORTS_DAYS=3
ABUSE_THROTTLE_POSTING_VELOCITY_HOURS=1
ABUSE_THROTTLE_LOW_TRUST_HOURS=6
ABUSE_PROFILE_AVATAR_TRUST_BONUS=10
ABUSE_PROFILE_BIO_TRUST_BONUS=8
ABUSE_HAS_POSTS_TRUST_BONUS=5
ABUSE_HAS_LIKED_TRUST_BONUS=5
ABUSE_HAS_FOLLOWERS_TRUST_BONUS=10
ABUSE_HAS_FOLLOWING_TRUST_BONUS=5
DEAD_LETTER_REPLAY_MAX_COUNT=5
DEAD_LETTER_REPLAY_COOLDOWN_SECONDS=300
CSP_ENFORCE_ENABLED=False
CSP_ENFORCE_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: https:; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
CSP_REPORT_ONLY_ENABLED=False
CSP_REPORT_ONLY_POLICY=default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data: https:; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
API_THROTTLE_USER=120/min
API_THROTTLE_ANON=60/min
